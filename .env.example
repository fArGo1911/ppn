# PPN POC — environment example (SAFE TO COMMIT). Copy to `.env` (git-ignored) and fill local values.
# NEVER commit a real `.env` or real keys.

# App base path: "/" for the subdomain root (ppn.todeloo.com) or "/ppn" if served under a subpath.
VITE_PPN_BASE_PATH=/
# Public base URLs used to build links / QR join codes (no hardcoded localhost in business logic).
VITE_PPN_BASE_URL=http://localhost:5173
VITE_PPN_QR_BASE_URL=http://localhost:5173

# Isolated PPN LOCAL Supabase (filled from `supabase start` output — DO NOT use the tippick stack on 54321).
VITE_SUPABASE_URL=http://localhost:55321
VITE_SUPABASE_ANON_KEY=

# Simple demo password gate (designed for future public deployment; trivial locally).
VITE_DEMO_PASSWORD=

# POC operator gate code for /config and /host (NOT production auth). Falls back to "demo" if unset.
VITE_PPN_OPERATOR_CODE=demo
